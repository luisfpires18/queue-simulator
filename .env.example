# Dev: SQLite (default, zero infra)
DATABASE_URL="file:./dev.db"

# Prod: Postgres (see docker-compose.yml). Switch prisma/schema.prisma provider to "postgresql".
# DATABASE_URL="postgresql://gf:gf@localhost:5432/groupfinder?schema=public"

# Auth.js session secret — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Battle.net OAuth login (+ later: real character/M+ data)
# Client: https://develop.battle.net/access/clients
# Redirect URL: http://localhost:3200/api/auth/callback/battlenet
BLIZZARD_CLIENT_ID=""
BLIZZARD_CLIENT_SECRET=""
BLIZZARD_REGION="eu"

# Dev-only login bypass: signs in as the fake user seeded by prisma/seed.ts
# (bnetId "dev-fake-1") without going through real Battle.net OAuth — lets you
# test logged-in flows without your real account. NEVER set this in
# production; authorize() also only ever accepts "dev-fake-*" bnetIds as a
# second guard. Leave unset/"0" normally.
ALLOW_DEV_LOGIN="0"

# --- Warcraft Logs client-credentials (app token only, no user login) ---
# Powers parse analysis under /parses. Create a client (uncheck "Public client"):
# https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=""
WCL_CLIENT_SECRET=""

# --- Web push (VAPID) — generate with: npx web-push generate-vapid-keys ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
